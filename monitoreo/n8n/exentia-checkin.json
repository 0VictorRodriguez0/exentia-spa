      "parameters": {
        "jsCode": "let body = $input.item.json.body || $input.item.json;\nif (typeof body === 'string') { try { body = JSON.parse(body); } catch(e) { body = {}; } }\nbody = body || {};\nif (!body.booking_id) throw new Error('booking_id requerido');\nconst payload = {\n  booking_id: body.booking_id,\n  lat: body.lat ?? null,\n  lng: body.lng ?? null\n};\nreturn { json: { payload } };"
      },
