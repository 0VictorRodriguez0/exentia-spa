      "name": "Normalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE exentia.bookings\nSET checkin_terapeuta_at = now(),\n    checkin_lat = NULLIF(($1::jsonb)->>'lat','')::numeric,\n    checkin_lng = NULLIF(($1::jsonb)->>'lng','')::numeric,\n    estado = 'asistio'\nWHERE id = (($1::jsonb)->>'booking_id')::uuid\nRETURNING id, booking_code, checkin_terapeuta_at;",
        "options": {
          "queryReplacement": "={{ JSON.stringify($json.payload) }}"
        }
      },
